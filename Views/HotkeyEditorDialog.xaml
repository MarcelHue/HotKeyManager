<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HotKeyManager.Views.HotkeyEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HotKeyManager.Views"
    Title="Hotkey bearbeiten"
    PrimaryButtonText="Speichern"
    CloseButtonText="Abbrechen"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    Closing="ContentDialog_Closing">
    
    <Grid x:Name="RootPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <InfoBar x:Name="ErrorInfoBar" 
                 Grid.Row="0"
                 Severity="Error" 
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0,0,0,12" />
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>
            
            <ScrollViewer x:Name="MainScrollViewer" 
                          Grid.Column="1"
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ContentStackPanel" Spacing="20" MinWidth="400">
            
            <!-- Name -->
            <StackPanel Spacing="8">
                <TextBlock Text="Name" FontWeight="SemiBold" />
                <TextBox x:Name="NameTextBox" PlaceholderText="z.B. Browser öffnen" MaxLength="100" />
            </StackPanel>
            
            <!-- Hotkey -->
            <StackPanel Spacing="8">
                <TextBlock Text="Tastenkombination" FontWeight="SemiBold" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" 
                            Background="{ThemeResource ControlFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4" 
                            Padding="12,10">
                        <TextBlock x:Name="HotkeyDisplayText" 
                                   Text="Nicht gesetzt"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Button x:Name="CaptureKeyButton"
                            Grid.Column="1" 
                            Margin="8,0,0,0"
                            Click="CaptureKey_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE765;" FontSize="14" />
                            <TextBlock Text="Erfassen" />
                        </StackPanel>
                    </Button>
                </Grid>
                
                <!-- Kernel-Mode Interception Option -->
                <CheckBox x:Name="KernelInterceptionCheckBox" 
                          Content="Kernel-Mode Interception (für Remote Desktop)"
                          Checked="KernelInterception_Changed"
                          Unchecked="KernelInterception_Changed"
                          Margin="0,8,0,0" />
                <InfoBar x:Name="KernelInterceptionWarning"
                         Severity="Warning"
                         Title="Treiber nicht installiert"
                         Message="Der Interception-Treiber ist nicht installiert. Bitte installiere ihn in den Einstellungen."
                         IsOpen="False"
                         IsClosable="False" />
            </StackPanel>
            
            <!-- Window Targeting Options -->
            <StackPanel Spacing="8">
                <TextBlock Text="Fenster-Optionen" FontWeight="SemiBold" />
                <RadioButtons x:Name="WindowModeRadioButtons" 
                              SelectionChanged="WindowMode_SelectionChanged">
                    <RadioButton x:Name="WindowModeNone" Content="Keine Beschränkung" Tag="None" IsChecked="True" />
                    <RadioButton x:Name="WindowModeOnlyActive" Content="Nur bei aktivem Fenster auslösen" Tag="OnlyWhenActive" />
                    <RadioButton x:Name="WindowModeSendToBackground" Content="Tasten an Hintergrund-Fenster senden" Tag="SendToBackground" />
                </RadioButtons>
                
                <!-- Window Target Configuration (nur sichtbar wenn Modus != None) -->
                <StackPanel x:Name="WindowTargetConfig" Spacing="12" Visibility="Collapsed" Margin="0,8,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Prozessname" FontWeight="SemiBold" />
                        <TextBox x:Name="TargetProcessNameTextBox" 
                                 PlaceholderText="z.B. notepad, chrome (ohne .exe)" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Fenstertitel (optional)" FontWeight="SemiBold" />
                        <TextBox x:Name="TargetWindowTitleTextBox" 
                                 PlaceholderText="z.B. *Editor* (* als Wildcard)" />
                    </StackPanel>
                    <Button x:Name="CaptureWindowButton" Click="CaptureWindow_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE78B;" FontSize="14" />
                            <TextBlock x:Name="CaptureWindowButtonText" Text="Fenster auswählen (3s)" />
                        </StackPanel>
                    </Button>
                    <InfoBar x:Name="WindowCaptureInfoBar"
                             Severity="Informational"
                             Title="Fenster erfassen"
                             Message="Klicke auf das gewünschte Fenster innerhalb von 3 Sekunden."
                             IsOpen="False"
                             IsClosable="False" />
                </StackPanel>
            </StackPanel>
            
            <!-- Action Type -->
            <StackPanel Spacing="8">
                <TextBlock Text="Aktionstyp" FontWeight="SemiBold" />
                <ComboBox x:Name="ActionTypeComboBox" 
                          HorizontalAlignment="Stretch"
                          SelectionChanged="ActionType_SelectionChanged">
                    <ComboBoxItem Content="Webhook aufrufen" Tag="Webhook" />
                    <ComboBoxItem Content="Tastensequenz senden" Tag="KeySequence" />
                    <ComboBoxItem Content="Programm starten" Tag="Process" />
                    <ComboBoxItem Content="Batch-Befehl ausführen" Tag="Batch" />
                    <ComboBoxItem Content="Text senden" Tag="SendText" />
                </ComboBox>
            </StackPanel>
            
            <!-- Webhook Configuration -->
            <StackPanel x:Name="WebhookConfig" Spacing="12" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="URL" FontWeight="SemiBold" />
                    <TextBox x:Name="WebhookUrlTextBox" 
                             PlaceholderText="https://api.example.com/webhook" />
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="HTTP-Methode" FontWeight="SemiBold" />
                    <ComboBox x:Name="HttpMethodComboBox" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="GET" IsSelected="True" />
                        <ComboBoxItem Content="POST" />
                        <ComboBoxItem Content="PUT" />
                        <ComboBoxItem Content="DELETE" />
                        <ComboBoxItem Content="PATCH" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="Content-Type" FontWeight="SemiBold" />
                    <ComboBox x:Name="ContentTypeComboBox" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="application/json" IsSelected="True" />
                        <ComboBoxItem Content="application/x-www-form-urlencoded" />
                        <ComboBoxItem Content="text/plain" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="Body (optional)" FontWeight="SemiBold" />
                    <TextBox x:Name="WebhookBodyTextBox" 
                             PlaceholderText="{}{&quot;key&quot;: &quot;value&quot;}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
            
            <!-- Key Sequence Configuration -->
            <StackPanel x:Name="KeySequenceConfig" Spacing="12" Visibility="Collapsed">
                <!-- Mode Toggle -->
                <CheckBox x:Name="AdvancedModeCheckBox" 
                          Content="Erweiterter Modus (separate KeyDown/KeyUp für Kombinationen)"
                          Checked="AdvancedMode_Changed"
                          Unchecked="AdvancedMode_Changed" />
                
                <StackPanel Spacing="8">
                    <!-- Header mit Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tastenfolge" FontWeight="SemiBold" VerticalAlignment="Center" />
                        
                        <!-- Simple Mode: Einzelne Taste hinzufügen -->
                        <Button x:Name="AddKeyStrokeButton" Grid.Column="1" Click="AddKeyStroke_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                <TextBlock Text="Taste hinzufügen" />
                            </StackPanel>
                        </Button>
                        
                        <!-- Advanced Mode: Aufnahme starten/stoppen -->
                        <Button x:Name="RecordButton" Grid.Column="2" 
                                Click="ToggleRecording_Click"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="RecordIcon" Glyph="&#xE7C8;" FontSize="12" />
                                <TextBlock x:Name="RecordButtonText" Text="Aufnahme starten" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    
                    <!-- Info für Advanced Mode -->
                    <InfoBar x:Name="AdvancedModeInfoBar"
                             Severity="Informational"
                             Title="Erweiterter Modus"
                             Message="Klicke 'Aufnahme starten', drücke deine Tastenkombination, dann 'Aufnahme stoppen'. Jedes KeyDown und KeyUp wird separat aufgezeichnet."
                             IsOpen="False"
                             IsClosable="False" />
                    
                    <!-- ListView mit Drag & Drop -->
                    <ListView x:Name="KeyStrokesListView" 
                              SelectionMode="None"
                              CanReorderItems="True"
                              AllowDrop="True"
                              CanDragItems="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Drag Handle -->
                                    <FontIcon Grid.Column="0" 
                                              Glyph="&#xE700;" 
                                              FontSize="12" 
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              ToolTipService.ToolTip="Ziehen zum Umsortieren" />
                                    
                                    <!-- Key Display (zeigt EventType im Advanced Mode) -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayTextWithType}" 
                                               VerticalAlignment="Center" 
                                               FontFamily="Consolas" />
                                    
                                    <NumberBox Grid.Column="2" 
                                               Header="Verzögerung (ms)"
                                               Value="{Binding DelayAfterMs, Mode=TwoWay}"
                                               Minimum="0"
                                               Maximum="10000"
                                               SpinButtonPlacementMode="Compact"
                                               Margin="8,0" />
                                    <Button Grid.Column="3" 
                                            Background="Transparent"
                                            Click="RemoveKeyStroke_Click"
                                            Tag="{Binding}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#EF4444" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    
                    <!-- Hinweis wenn Liste leer -->
                    <TextBlock x:Name="EmptyKeyStrokesHint"
                               Text="Noch keine Tasten hinzugefügt"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="Visible" />
                </StackPanel>
            </StackPanel>
            
            <!-- Process Configuration -->
            <StackPanel x:Name="ProcessConfig" Spacing="12" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Programmpfad" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ProcessPathTextBox" 
                                 PlaceholderText="C:\Program Files\..." />
                        <Button Grid.Column="1" Margin="8,0,0,0" Click="BrowseFile_Click">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="Argumente (optional)" FontWeight="SemiBold" />
                    <TextBox x:Name="ProcessArgsTextBox" 
                             PlaceholderText="--flag value" />
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="Arbeitsverzeichnis (optional)" FontWeight="SemiBold" />
                    <TextBox x:Name="ProcessWorkDirTextBox" 
                             PlaceholderText="C:\..." />
                </StackPanel>
                <CheckBox x:Name="ProcessRunAsAdminCheckBox" Content="Als Administrator ausführen" />
                <CheckBox x:Name="ProcessHiddenCheckBox" Content="Versteckt starten" />
            </StackPanel>
            
            <!-- Batch Configuration -->
            <StackPanel x:Name="BatchConfig" Spacing="12" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Befehl" FontWeight="SemiBold" />
                    <TextBox x:Name="BatchCommandTextBox" 
                             PlaceholderText="echo Hello World"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Spacing="8">
                    <TextBlock Text="Arbeitsverzeichnis (optional)" FontWeight="SemiBold" />
                    <TextBox x:Name="BatchWorkDirTextBox" 
                             PlaceholderText="C:\..." />
                </StackPanel>
                <CheckBox x:Name="BatchHiddenCheckBox" Content="Versteckt ausführen" IsChecked="True" />
                <CheckBox x:Name="BatchWaitCheckBox" Content="Auf Beendigung warten" />
            </StackPanel>
            
            <!-- Send Text Configuration -->
            <StackPanel x:Name="SendTextConfig" Spacing="12" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Text" FontWeight="SemiBold" />
                    <TextBox x:Name="SendTextTextBox" 
                             PlaceholderText="Text der gesendet werden soll..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="100" />
                </StackPanel>
                <InfoBar Severity="Informational"
                         Title="Hinweis"
                         Message="Der Text wird als simulierte Tastatureingaben gesendet. Zeilenumbrüche werden als Enter-Taste gesendet."
                         IsOpen="True"
                         IsClosable="False" />
            </StackPanel>
            
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ContentDialog>
