<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HotKeyManager.Views.KeyCaptureDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HotKeyManager.Views"
    Title="Taste erfassen"
    PrimaryButtonText="Übernehmen"
    CloseButtonText="Abbrechen"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    Opened="ContentDialog_Opened"
    Closed="ContentDialog_Closed">
    
    <StackPanel Spacing="24" MinWidth="350" Padding="16">
        <TextBlock Text="Drücke die gewünschte Tastenkombination..."
                   TextAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        
        <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="32,24"
                HorizontalAlignment="Center">
            <TextBlock x:Name="KeyDisplayText"
                       Text="Warte auf Eingabe..."
                       FontFamily="Consolas"
                       FontSize="24"
                       FontWeight="Bold"
                       TextAlignment="Center" />
        </Border>
        
        <TextBlock Text="Tipp: Halte Modifier (Ctrl, Alt, Shift, Win) gedrückt und drücke eine Taste"
                   TextAlignment="Center"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
