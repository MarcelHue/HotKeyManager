<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HotKeyManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HotKeyManager.Views"
    Background="Transparent">
    
    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="600">
            
            <!-- Header -->
            <TextBlock Text="Einstellungen" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}" />
            
            <!-- General Settings -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="24">
                <StackPanel Spacing="20">
                    <TextBlock Text="Allgemein" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mit Windows starten" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="HotKey Manager automatisch beim Systemstart öffnen" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoStartToggle" 
                                      Grid.Column="1"
                                      OnContent="" 
                                      OffContent=""
                                      Toggled="AutoStartToggle_Toggled" />
                    </Grid>
                    
                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="In System Tray minimieren" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Beim Schließen des Fensters in den System Tray minimieren" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="MinimizeToTrayToggle" 
                                      Grid.Column="1"
                                      OnContent="" 
                                      OffContent=""
                                      Toggled="MinimizeToTrayToggle_Toggled" />
                    </Grid>
                    
                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Minimiert starten" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="App beim Start direkt in den System Tray minimieren" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="StartMinimizedToggle" 
                                      Grid.Column="1"
                                      OnContent="" 
                                      OffContent=""
                                      Toggled="StartMinimizedToggle_Toggled" />
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Data Management -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="24">
                <StackPanel Spacing="20">
                    <TextBlock Text="Daten" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Konfiguration exportieren" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Alle Hotkeys als JSON-Datei exportieren" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Click="ExportConfig_Click"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="14" />
                                <TextBlock Text="Exportieren" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    
                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Konfiguration importieren" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Hotkeys aus einer JSON-Datei importieren" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Click="ImportConfig_Click"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                                <TextBlock Text="Importieren" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    
                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Alle Daten löschen" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Alle Hotkeys und Einstellungen zurücksetzen" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Click="ResetConfig_Click"
                                Padding="16,8"
                                Background="#7F1D1D">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#EF4444" />
                                <TextBlock Text="Zurücksetzen" Foreground="#EF4444" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Kernel-Mode Driver -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="24">
                <StackPanel Spacing="20">
                    <TextBlock Text="Kernel-Mode Treiber" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Der Interception-Treiber ermoeglicht Kernel-Mode Tastatur-Injektion (Tasten ohne LLKHF_INJECTED-Flag senden)." 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Treiber-Status" 
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="DriverStatusDot" Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" />
                                <TextBlock x:Name="DriverStatusLabel" 
                                           Text="Nicht installiert" 
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="DriverActionButton" 
                                Grid.Column="1" 
                                Click="DriverAction_Click"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="DriverActionIcon" Glyph="&#xE896;" FontSize="14" />
                                <TextBlock x:Name="DriverActionText" Text="Installieren" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- About -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="Über HotKey Manager" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Version 1.0.0" 
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="Ein globaler Hotkey Manager für Windows mit Unterstützung für Webhooks, Tastensequenzen, Programmstart und Batch-Befehle." 
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
