<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HotKeyManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="32,24,32,0" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Stretch" Margin="0,0,0,24">

            <TextBlock Text="Einstellungen" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Darstellung -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Darstellung" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <RadioButtons Header="Design"
                                  SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                        <RadioButton Content="Hell" />
                        <RadioButton Content="Dunkel" />
                        <RadioButton Content="System" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Allgemein -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Allgemein" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Mit Windows starten" />
                            <TextBlock Text="HotKey Manager automatisch beim Systemstart öffnen"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"
                                      IsOn="{x:Bind ViewModel.AutoStart, Mode=TwoWay}" />
                    </Grid>

                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="In System Tray minimieren" />
                            <TextBlock Text="Beim Schließen des Fensters in den System Tray minimieren"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"
                                      IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                    </Grid>

                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Minimiert starten" />
                            <TextBlock Text="App beim Start direkt in den System Tray minimieren"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"
                                      IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Logging -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Logging" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Log-Level" />
                            <TextBlock Text="Bestimmt, welche Meldungen in die Log-Datei geschrieben werden (%APPDATA%\HotKeyManager\hotkey-manager.log)"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="150"
                                  VerticalAlignment="Center"
                                  SelectedIndex="{x:Bind ViewModel.LogLevelIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Info" />
                            <ComboBoxItem Content="Warnung" />
                            <ComboBoxItem Content="Fehler" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Kernel-Mode Treiber -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Kernel-Mode Treiber" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <InfoBar IsOpen="True"
                             IsClosable="False"
                             Severity="{x:Bind ViewModel.DriverSeverity, Mode=OneWay}"
                             Title="Treiber-Status"
                             Message="{x:Bind ViewModel.DriverStatusMessage, Mode=OneWay}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Interception-Treiber" />
                            <TextBlock Text="Ermöglicht Kernel-Mode Tasteninjektion ohne LLKHF_INJECTED Flag"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="InstallDriver_Click"
                                IsEnabled="{x:Bind ViewModel.IsDriverButtonEnabled, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="{x:Bind ViewModel.DriverButtonGlyph, Mode=OneWay}" FontSize="14" />
                                <TextBlock Text="{x:Bind ViewModel.DriverButtonText, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Konfiguration -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Konfiguration" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Konfiguration exportieren" />
                            <TextBlock Text="Alle Hotkeys als JSON-Datei exportieren"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Center" Click="ExportConfig_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="14" />
                                <TextBlock Text="Exportieren" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Konfiguration importieren" />
                            <TextBlock Text="Hotkeys aus einer JSON-Datei importieren"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Center" Click="ImportConfig_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                                <TextBlock Text="Importieren" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Alle Daten löschen" />
                            <TextBlock Text="Alle Hotkeys und Einstellungen zurücksetzen"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Center" Click="ResetConfig_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#EF4444" />
                                <TextBlock Text="Zurücksetzen" Foreground="#EF4444" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Über -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Über HotKey Manager" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.VersionText}" />
                            <TextBlock Text="Updates werden über GitHub Releases verteilt"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CheckUpdatesButton"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="CheckUpdates_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                                <TextBlock x:Name="CheckUpdatesButtonText" Text="Nach Updates suchen" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="Ein globaler Hotkey Manager für Windows mit Unterstützung für Webhooks, Tastensequenzen, Text-Makros, Programmstart und Batch-Befehle."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
