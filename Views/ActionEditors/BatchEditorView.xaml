<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HotKeyManager.Views.ActionEditors.BatchEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12">
        <TextBox Header="Befehl"
                 Text="{x:Bind ViewModel.Command, Mode=TwoWay}"
                 PlaceholderText="echo Hello World"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"
                 MaxHeight="200"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />

        <TextBox Header="Arbeitsverzeichnis (optional)"
                 Text="{x:Bind ViewModel.WorkingDirectory, Mode=TwoWay}"
                 PlaceholderText="C:\..." />

        <CheckBox Content="Versteckt ausführen"
                  IsChecked="{x:Bind ViewModel.RunHidden, Mode=TwoWay}" />
        <CheckBox Content="Auf Beendigung warten"
                  IsChecked="{x:Bind ViewModel.WaitForExit, Mode=TwoWay}" />
    </StackPanel>
</UserControl>
