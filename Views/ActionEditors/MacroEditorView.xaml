<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HotKeyManager.Views.ActionEditors.MacroEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="using:HotKeyManager.Views.ActionEditors">

    <UserControl.Resources>
        <!-- Bausteine nutzen dieselben Editor-Controls wie die Top-Level-Aktionstypen -->
        <DataTemplate x:Key="StepSendTextTemplate">
            <ae:SendTextEditorView />
        </DataTemplate>
        <DataTemplate x:Key="StepKeySequenceTemplate">
            <ae:KeySequenceEditorView />
        </DataTemplate>
        <DataTemplate x:Key="StepDelayTemplate">
            <ae:DelayEditorView />
        </DataTemplate>
        <DataTemplate x:Key="StepWebhookTemplate">
            <ae:WebhookEditorView />
        </DataTemplate>
        <DataTemplate x:Key="StepProcessTemplate">
            <ae:ProcessEditorView />
        </DataTemplate>
        <DataTemplate x:Key="StepBatchTemplate">
            <ae:BatchEditorView />
        </DataTemplate>

        <ae:ActionEditorTemplateSelector x:Key="StepEditorSelector"
                                         SendTextTemplate="{StaticResource StepSendTextTemplate}"
                                         KeySequenceTemplate="{StaticResource StepKeySequenceTemplate}"
                                         DelayTemplate="{StaticResource StepDelayTemplate}"
                                         WebhookTemplate="{StaticResource StepWebhookTemplate}"
                                         ProcessTemplate="{StaticResource StepProcessTemplate}"
                                         BatchTemplate="{StaticResource StepBatchTemplate}" />
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Bausteine" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Werden von oben nach unten ausgeführt — Reihenfolge per Ziehen ändern"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                    <TextBlock Text="Baustein hinzufügen" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuFlyoutItem Text="Text eingeben" Tag="sendtext" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8D2;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Tastendruck / Tastensequenz" Tag="keysequence" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE765;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Verzögerung" Tag="delay" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE916;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Webhook aufrufen" Tag="webhook" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE774;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Programm starten" Tag="process" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE756;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Batch-Befehl ausführen" Tag="batch" Click="AddStep_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7AC;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <NumberBox Header="Verzögerung zwischen Bausteinen (ms)"
                   Value="{x:Bind ViewModel.StepDelayMs, Mode=TwoWay}"
                   Minimum="0"
                   Maximum="60000"
                   SmallChange="50"
                   SpinButtonPlacementMode="Inline"
                   HorizontalAlignment="Left"
                   MinWidth="280" />

        <ListView ItemsSource="{x:Bind ViewModel.Steps, Mode=OneWay}"
                  SelectionMode="None"
                  CanReorderItems="True"
                  AllowDrop="True"
                  CanDragItems="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Expander HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE700;"
                                          FontSize="12"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          ToolTipService.ToolTip="Ziehen zum Umsortieren" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8"
                                        VerticalAlignment="Center"
                                        Click="RemoveStep_Click"
                                        ToolTipService.ToolTip="Baustein entfernen">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#EF4444" />
                                </Button>
                            </Grid>
                        </Expander.Header>
                        <ContentControl Content="{Binding}"
                                        ContentTemplateSelector="{StaticResource StepEditorSelector}"
                                        HorizontalContentAlignment="Stretch"
                                        IsTabStop="False" />
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Text="Noch keine Bausteine — füge über „Baustein hinzufügen“ den ersten Schritt hinzu."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   FontStyle="Italic"
                   Visibility="{x:Bind ViewModel.IsEmptyHintVisible, Mode=OneWay}" />
    </StackPanel>
</UserControl>
