<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HotKeyManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HotKeyManager"
    Title="HotKey Manager">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar (Drag-Area) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE765;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                <TextBlock Text="HotKey Manager"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        OpenPaneLength="260"
                        IsSettingsVisible="True"
                        IsPaneToggleButtonVisible="False"
                        IsBackButtonVisible="Auto"
                        IsBackEnabled="False"
                        SelectionChanged="NavView_SelectionChanged"
                        BackRequested="NavView_BackRequested">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HotkeysNavItem" Content="Hotkeys" Tag="hotkeys">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE765;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="16,0,16,8" Spacing="8">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Hook Status"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{x:Bind ViewModel.HookStatusBrush, Mode=OneWay}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.HookStatusText, Mode=OneWay}"
                                               FontSize="13" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Kernel-Treiber"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{x:Bind ViewModel.DriverStatusBrush, Mode=OneWay}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.DriverStatusText, Mode=OneWay}"
                                               FontSize="13" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.VersionText}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Update-Benachrichtigung -->
                <InfoBar Grid.Row="0"
                         Severity="Informational"
                         Title="Update verfügbar"
                         Margin="16,8,16,0"
                         Message="{x:Bind ViewModel.UpdateBannerText, Mode=OneWay}"
                         IsOpen="{x:Bind ViewModel.IsUpdateBannerVisible, Mode=TwoWay}">
                    <InfoBar.ActionButton>
                        <Button Content="{x:Bind ViewModel.UpdateButtonText, Mode=OneWay}"
                                Command="{x:Bind ViewModel.UpdateNowCommand}"
                                IsEnabled="{x:Bind ViewModel.IsUpdateButtonEnabled, Mode=OneWay}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <Frame x:Name="ContentFrame" Grid.Row="1" Navigated="ContentFrame_Navigated" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
