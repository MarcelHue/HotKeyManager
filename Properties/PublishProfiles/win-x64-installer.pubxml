<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>bin\publish\win-x64\</PublishDir>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

  <Target Name="AfterPublish">
    <PropertyGroup>
      <InnoSetupExe>C:\Program Files (x86)\Inno Setup 6\ISCC.exe</InnoSetupExe>
      <InstallerScript>$(MSBuildProjectDirectory)\installer\setup.iss</InstallerScript>
    </PropertyGroup>
    <Error Condition="!Exists('$(InnoSetupExe)')"
           Text="Inno Setup nicht gefunden: $(InnoSetupExe). Bitte Inno Setup 6 installieren." />
    <Error Condition="!Exists('$(InstallerScript)')"
           Text="Installer-Script nicht gefunden: $(InstallerScript)" />
    <Exec Command="&quot;$(InnoSetupExe)&quot; &quot;$(InstallerScript)&quot;"
          ConsoleToMSBuild="true" />
    <Message Text="Installer erfolgreich erstellt: $(MSBuildProjectDirectory)\installer\Output\HotKeyManager_Setup.exe"
             Importance="high" />
  </Target>
</Project>
